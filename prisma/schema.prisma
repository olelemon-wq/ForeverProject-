datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Tenant {
  id                  String             @id @default(uuid())
  slug                String             @unique
  name                String
  category            String             // e.g. "Memorial", "Family Legacy", "Couple", "Wedding", "Friends", "Pet Memorial"
  ownerPhone          String
  themeConfig         Json               // e.g. { primaryColor: "#Hex", secondaryColor: "#Hex", font: "Inter", heroStyle: "Classic" }
  visibility          String             // "PUBLIC", "PRIVATE", "PASSWORD_PROTECTED" (BR035)
  status              String             // "ACTIVE", "READ_ONLY", "SUSPENDED", "ARCHIVED" (BR021)
  expiredAt           DateTime
  donationPromptPay   String?
  donationAccountName String?
  donationActive      Boolean            @default(false)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  webmasters    WebsiteWebmaster[]
  subscriptions Subscription[]
  payments      Payment[]
  medias        Media[]
  condolences   Condolence[]
  menus         Menu[]
  auditLogs     AuditLog[]
  memoryPosts   MemoryPost[]
  familyMembers FamilyMember[]
  ebooks        Ebook[]
  donations     Donation[]
  memorialPosts MemorialPost[]
}

model Webmaster {
  id        String             @id @default(uuid())
  phone     String             @unique
  name      String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  websites      WebsiteWebmaster[]
  devices       TrustedDevice[]
  memorialPosts MemorialPost[]
}

model WebsiteWebmaster {
  id          String   @id @default(uuid())
  websiteId   String
  webmasterId String
  role        String   // "MAIN", "CO" (BR002, BR003)
  createdAt   DateTime @default(now())

  website   Tenant    @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  webmaster Webmaster @relation(fields: [webmasterId], references: [id], onDelete: Cascade)

  @@unique([websiteId, webmasterId])
}

model TrustedDevice {
  id                String    @id @default(uuid())
  webmasterId       String
  deviceFingerprint String
  userAgent         String
  ipAddress         String
  lastLoginAt       DateTime  @default(now())

  webmaster Webmaster @relation(fields: [webmasterId], references: [id], onDelete: Cascade)
}

model Subscription {
  id           String   @id @default(uuid())
  websiteId    String
  plan         String   // "FIRST_YEAR", "RENEWAL", "UPGRADE_S", "UPGRADE_M", "UPGRADE_L"
  storageQuota BigInt   // storage quota in bytes (e.g. 1GB = 1,073,741,824 bytes - BR013)
  status       String   // "ACTIVE", "EXPIRED", "SUSPENDED"
  startDate    DateTime
  endDate      DateTime
  createdAt    DateTime @default(now())

  website Tenant @relation(fields: [websiteId], references: [id], onDelete: Cascade)
}

model Payment {
  id        String   @id @default(uuid())
  websiteId String
  refId     String   @unique // Dynamic QR code reference or gateway transaction ID
  type      String   // "NEW_WEBSITE", "RENEWAL", "STORAGE_UPGRADE"
  amount    Float
  status    String   // "PENDING", "SUCCESS", "FAILED"
  receiptNo String?
  invoiceNo String?
  payload   Json?
  createdAt DateTime @default(now())

  website Tenant @relation(fields: [websiteId], references: [id], onDelete: Cascade)
}

model Media {
  id        String   @id @default(uuid())
  websiteId String
  filePath  String   // S3/R2 object storage path
  fileName  String
  fileSize  BigInt   // file size in bytes
  mimeType  String
  fileHash  String   // MD5/SHA hash of file for duplicate warning check (BR031)
  album     String?  // e.g. "GALLERY", "VIDEO", "AUDIO", "DOCUMENT"
  isDeleted Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  website Tenant @relation(fields: [websiteId], references: [id], onDelete: Cascade)
}

model Condolence {
  id           String   @id @default(uuid())
  websiteId    String
  senderName   String
  relationship String   // e.g. "Spouse", "Son", "Daughter", "Grandchild", "Relative", "Friend", "Colleague" (BR029)
  message      String
  type         String   // "FAMILY", "GENERAL" (BR028)
  isApproved   Boolean  @default(false) // Default requires approval (BR027)
  createdAt    DateTime @default(now())

  website Tenant @relation(fields: [websiteId], references: [id], onDelete: Cascade)
}

model Menu {
  id        String   @id @default(uuid())
  websiteId String
  title     String
  pageType  String   // e.g. "BIOGRAPHY", "TIMELINE", "GALLERY", "VIDEOS", "CONDOLENCE", "CONTACT"
  isVisible Boolean  @default(true)
  sortOrder Int
  parentId  String?
  createdAt DateTime @default(now())

  website Tenant @relation(fields: [websiteId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id          String   @id @default(uuid())
  websiteId   String?
  webmasterId String?
  action      String   // "LOGIN", "PAYMENT", "PUBLISH", "DELETE", "STORAGE" (BR036)
  details     String
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  website Tenant? @relation(fields: [websiteId], references: [id], onDelete: Cascade)
}

model OtpRequest {
  id        String   @id @default(uuid())
  phone     String   @unique
  code      String
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model MemoryPost {
  id         String   @id @default(uuid())
  websiteId  String
  title      String?
  content    String?
  mediaUrl   String?  // Image or video URL
  mediaType  String?  // "IMAGE", "VIDEO", "NONE"
  senderName String
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())

  website Tenant @relation(fields: [websiteId], references: [id], onDelete: Cascade)
}

model FamilyMember {
  id           String   @id @default(uuid())
  websiteId    String
  name         String
  nickname     String?
  relationship String   // e.g. "PARENT_1", "PARENT_2", "SPOUSE", "SIBLING", "CHILD"
  birthYear    String?
  deathYear    String?
  isDeceased   Boolean  @default(false)
  hideAge      Boolean  @default(false)
  avatarUrl    String?
  avatarScale  Float?   @default(1.0)
  avatarX      Float?   @default(0.0)
  avatarY      Float?   @default(0.0)
  avatarRotate Float?   @default(0.0)
  spouseOfId   String?
  parentId     String?
  createdAt    DateTime @default(now())

  website Tenant @relation(fields: [websiteId], references: [id], onDelete: Cascade)
}

model Ebook {
  id         String   @id @default(uuid())
  websiteId  String
  title      String
  author     String
  pdfUrl     String
  totalPages Int
  pages      Json     // Array of strings representing pages or chapter summaries
  createdAt  DateTime @default(now())

  website Tenant @relation(fields: [websiteId], references: [id], onDelete: Cascade)
}

model Donation {
  id          String   @id @default(uuid())
  websiteId   String
  donorName   String
  amount      Float
  message     String?
  isAnonymous Boolean  @default(false)
  hideAmount  Boolean  @default(false)
  slipUrl     String?
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())

  website Tenant @relation(fields: [websiteId], references: [id], onDelete: Cascade)
}

model Template {
  id           String   @id @default(uuid())
  name         String
  data         Json     // Stores Element arrays (Text, Image positions)
  ownerId      String?
  thumbnailUrl String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("templates")
}

model MemorialPost {
  id           String           @id @default(cuid())
  tenantId     String
  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  authorId     String?          // null = guest
  author       Webmaster?       @relation(fields: [authorId], references: [id])
  authorName   String           // snapshot name
  authorAvatar String?
  isAnonymous  Boolean          @default(false)
  type         MemorialPostType @default(CONDOLENCE)
  content      String           @db.Text
  mediaUrls    String[]         // S3 URLs (reusing existing file upload)
  isPinned     Boolean          @default(false)
  status       PostStatus       @default(PUBLISHED)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  reactions    PostReaction[]
  comments     PostComment[]

  @@index([tenantId, isPinned, createdAt])
}

model PostReaction {
  id        String       @id @default(cuid())
  postId    String
  post      MemorialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String?      // linked to Webmaster ID if logged in
  guestKey  String?      // cookie-based dedup for guests
  type      ReactionType
  createdAt DateTime     @default(now())

  @@unique([postId, userId])
  @@unique([postId, guestKey])
  @@index([postId])
}

model PostComment {
  id           String       @id @default(cuid())
  postId       String
  post         MemorialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId     String?
  authorName   String
  authorAvatar String?
  isAnonymous  Boolean      @default(false)
  content      String       @db.Text
  status       PostStatus   @default(PUBLISHED)
  createdAt    DateTime     @default(now())

  @@index([postId, createdAt])
}

enum MemorialPostType {
  CONDOLENCE
  MEMORY
  ANNOUNCEMENT
  MERIT
}

enum PostStatus {
  PUBLISHED
  PENDING
  HIDDEN
}

enum ReactionType {
  PRAY
  LOVE
  CANDLE
  FLOWER
}





