# FOREVER Platform - Environment Variables Template

# 1. Database Configurations
# URL format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/forever_db?schema=public"

# 2. Authentication & JWT Sessions
# Random long string used to encrypt session tokens
JWT_SECRET="generate_a_secure_random_string_here_512_bits"

# 3. Object Storage - Cloudflare R2 / AWS S3 compatible (BR014, BR016)
# If provided, the S3 Client will issue real presigned upload URLs directly to client browser
S3_ACCESS_KEY_ID="your_r2_or_s3_access_key_id"
S3_SECRET_ACCESS_KEY="your_r2_or_s3_secret_access_key"
S3_ENDPOINT="https://<account_id>.r2.cloudflarestorage.com"
S3_BUCKET_NAME="forever-memorial-storage"
# CDN or public domain to serve uploaded files (e.g. custom domain or R2 dev subdomains)
S3_PUBLIC_DOMAIN="https://storage.forever.co.th"

# 4. Bank Transfer Slip Verification (Phase 2 Grill Decision)
# SlipOk / EasySlip API key to scan and verify QR codes on PromtPay slips
SLIPOK_API_KEY="your_slipok_api_token"

# 5. Mobile OTP / SMS Dispatch Service (BR001, BR005)
# API keys for ThaiBulkSMS or equivalent SMS gateway
OTP_API_KEY="your_thaibulksms_api_key"
OTP_API_SECRET="your_thaibulksms_api_secret"

# 6. Payment Webhook Signatures (BR010, BR018)
# Expected signature key to verify incoming callbacks from payment gateways (e.g. GB Prime Pay)
PAYMENT_GATEWAY_KEY="MOCK_SIGNATURE_OK_2026"

# 7. Next.js Runtime
NODE_ENV="development"
PORT=3000
